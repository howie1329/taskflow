{
  "name": "taskflow-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@taskflow/frontend & npm run dev --workspace=@taskflow/backend",
    "dev:frontend": "npm run dev --workspace=@taskflow/frontend",
    "dev:backend": "npm run dev --workspace=@taskflow/backend",
    "build": "npm run build --workspace=@taskflow/frontend && npm run build --workspace=@taskflow/backend",
    "build:frontend": "npm run build --workspace=@taskflow/frontend",
    "build:backend": "npm run build --workspace=@taskflow/backend",
    "lint": "npm run lint --workspaces",
    "install:all": "npm install"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "prettier": "^3.0.0"
  }
}