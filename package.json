{
  "name": "taskflow-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@taskflow/web",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@taskflow/web",
    "start:web": "turbo run start --filter=@taskflow/web",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "engines": {
    "node": ">=25.0.0"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "shadcn": "^3.8.1",
    "turbo": "^2.0.0"
  }
}
